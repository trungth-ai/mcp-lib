# Copy sang .env và điền giá trị thật. KHÔNG commit .env.
# Xem docs/CLAUDE.md và 07-sprints.md (Sprint 0) — nhiều giá trị dưới đây
# còn là GIẢ ĐỊNH chưa xác minh trên hạ tầng thật.

# --- DSpace ---
DSPACE_VERSION=6.3
DSPACE_REST_BASE_URL=http://10.1.0.205:8088/rest
DSPACE_SOLR_BASE_URL=http://10.1.0.205:8088/solr
# Core Solr dùng cho search — TÊN GIẢ ĐỊNH, xác minh ở Sprint 0
DSPACE_SOLR_SEARCH_CORE=search
# Field full-text trong Solr — TÊN GIẢ ĐỊNH, xác minh ở Sprint 0
DSPACE_SOLR_FULLTEXT_FIELD=fulltext
# URL public dùng để build link hiển thị cho người dùng (không dùng để gọi API)
DSPACE_PUBLIC_BASE_URL=https://lib.hpu.edu.vn

# Service account đọc — KHÔNG dùng tài khoản cá nhân
DSPACE_SERVICE_EMAIL=
DSPACE_SERVICE_PASSWORD=

# --- Vector layer (Sprint 3, chưa dùng ở Sprint 1) ---
DATABASE_URL=postgresql://user:password@localhost:5432/hpu_library_mcp
GEMINI_API_KEY=

# --- MCP server ---
MCP_TRANSPORT=stdio
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_PORT=8800
LOG_LEVEL=INFO
